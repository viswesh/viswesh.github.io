---
interface Props {
  title: string;
  blurb: string;
  ctaLabel: string;
  ctaUrl: string;
}
const { title, blurb, ctaLabel, ctaUrl } = Astro.props;
---
<a href={ctaUrl} data-tilt class="card-glass card-tick group block p-8 sm:p-12">
  <h3 class="text-3xl sm:text-4xl leading-tight" style="font-family: var(--font-display); font-weight: 600;">{title}</h3>
  <p class="mt-4 text-base sm:text-lg max-w-3xl text-[var(--color-muted)]">{blurb}</p>
  <span class="inline-block mt-6 font-mono text-sm transition group-hover:text-[var(--color-accent)] group-hover:translate-x-1">{ctaLabel} →</span>
</a>
