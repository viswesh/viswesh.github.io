---
// 3D enterprise context graph: clustered nodes, lineage edges, agent pulses
// walking the graph. Renders into the hero background.
---
<div class="graph-stage" aria-hidden="true">
  <canvas id="context-graph"></canvas>
</div>
<div class="graph-fade" aria-hidden="true"></div>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('context-graph') as HTMLCanvasElement | null;

  if (canvas) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 640px)').matches;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(0, 0, 13);

    // --- Build graph: clusters of nodes (domains) linked by lineage edges ---
    const CLUSTERS = isMobile ? 5 : 7;
    const PER_CLUSTER = isMobile ? 12 : 18;
    const centers: THREE.Vector3[] = [];
    for (let i = 0; i < CLUSTERS; i++) {
      const phi = Math.acos(2 * ((i + 0.5) / CLUSTERS) - 1);
      const theta = Math.PI * (1 + Math.sqrt(5)) * i;
      centers.push(new THREE.Vector3(
        4.6 * Math.sin(phi) * Math.cos(theta),
        3.2 * Math.cos(phi),
        4.6 * Math.sin(phi) * Math.sin(theta)
      ));
    }

    const nodes: THREE.Vector3[] = [];
    const nodeCluster: number[] = [];
    centers.forEach((c, ci) => {
      for (let i = 0; i < PER_CLUSTER; i++) {
        nodes.push(new THREE.Vector3(
          c.x + (Math.random() - 0.5) * 3.4,
          c.y + (Math.random() - 0.5) * 2.6,
          c.z + (Math.random() - 0.5) * 3.4
        ));
        nodeCluster.push(ci);
      }
    });

    // Edges: nearest neighbours within a cluster + sparse cross-cluster links
    const edges: [number, number][] = [];
    const adjacency: number[][] = nodes.map(() => []);
    function link(a: number, b: number) {
      edges.push([a, b]);
      adjacency[a].push(b);
      adjacency[b].push(a);
    }
    for (let i = 0; i < nodes.length; i++) {
      let best = -1;
      let bestD = Infinity;
      let second = -1;
      let secondD = Infinity;
      for (let j = 0; j < nodes.length; j++) {
        if (i === j || nodeCluster[i] !== nodeCluster[j]) continue;
        const d = nodes[i].distanceToSquared(nodes[j]);
        if (d < bestD) { second = best; secondD = bestD; best = j; bestD = d; }
        else if (d < secondD) { second = j; secondD = d; }
      }
      if (best >= 0 && i < best) link(i, best);
      if (second >= 0 && i < second && Math.random() < 0.5) link(i, second);
    }
    for (let i = 0; i < CLUSTERS * 2; i++) {
      const a = Math.floor(Math.random() * nodes.length);
      const b = Math.floor(Math.random() * nodes.length);
      if (a !== b && nodeCluster[a] !== nodeCluster[b]) link(a, b);
    }

    // --- Node sprites ---
    function circleTexture(color: string) {
      const c = document.createElement('canvas');
      c.width = c.height = 64;
      const ctx = c.getContext('2d')!;
      const g = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
      g.addColorStop(0, color);
      g.addColorStop(0.4, color);
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, 64, 64);
      const tex = new THREE.CanvasTexture(c);
      tex.colorSpace = THREE.SRGBColorSpace;
      return tex;
    }

    const steel = new THREE.Color('#5A6E8F');
    const amber = new THREE.Color('#FFB224');
    const teal = new THREE.Color('#5EEAD4');
    const positions = new Float32Array(nodes.length * 3);
    const colors = new Float32Array(nodes.length * 3);
    const sizes = new Float32Array(nodes.length);
    nodes.forEach((n, i) => {
      positions.set([n.x, n.y, n.z], i * 3);
      const r = Math.random();
      const col = r < 0.72 ? steel : r < 0.9 ? amber : teal;
      colors.set([col.r, col.g, col.b], i * 3);
      sizes[i] = r < 0.72 ? 1 : 1.6;
    });
    const nodeGeo = new THREE.BufferGeometry();
    nodeGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    nodeGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
    const nodeMat = new THREE.PointsMaterial({
      size: 0.16,
      map: circleTexture('#FFFFFF'),
      vertexColors: true,
      transparent: true,
      opacity: 0.9,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      sizeAttenuation: true,
    });
    const points = new THREE.Points(nodeGeo, nodeMat);

    // --- Edge lines ---
    const edgePositions = new Float32Array(edges.length * 6);
    edges.forEach(([a, b], i) => {
      edgePositions.set([nodes[a].x, nodes[a].y, nodes[a].z, nodes[b].x, nodes[b].y, nodes[b].z], i * 6);
    });
    const edgeGeo = new THREE.BufferGeometry();
    edgeGeo.setAttribute('position', new THREE.BufferAttribute(edgePositions, 3));
    const edgeMat = new THREE.LineBasicMaterial({
      color: '#2A3B5C',
      transparent: true,
      opacity: 0.38,
      depthWrite: false,
    });
    const lines = new THREE.LineSegments(edgeGeo, edgeMat);

    // --- Agent pulses walking edges ---
    const PULSES = reduced ? 0 : isMobile ? 3 : 5;
    const pulseTex = circleTexture('#FFCE6B');
    const pulses: { sprite: THREE.Sprite; from: number; to: number; t: number; speed: number }[] = [];
    for (let i = 0; i < PULSES; i++) {
      const mat = new THREE.SpriteMaterial({
        map: pulseTex,
        color: '#FFB224',
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      const sprite = new THREE.Sprite(mat);
      sprite.scale.setScalar(0.34);
      const from = Math.floor(Math.random() * nodes.length);
      const to = adjacency[from][0] ?? from;
      pulses.push({ sprite, from, to, t: Math.random(), speed: 0.5 + Math.random() * 0.5 });
    }

    const group = new THREE.Group();
    group.add(lines, points, ...pulses.map((p) => p.sprite));
    group.rotation.x = 0.18;
    scene.add(group);

    // --- Sizing ---
    function resize() {
      const { clientWidth: w, clientHeight: h } = canvas.parentElement!;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    // --- Pointer parallax ---
    let targetX = 0;
    let targetY = 0;
    if (!reduced && window.matchMedia('(hover: hover)').matches) {
      window.addEventListener('pointermove', (e) => {
        targetX = (e.clientX / window.innerWidth - 0.5) * 0.3;
        targetY = (e.clientY / window.innerHeight - 0.5) * 0.18;
      }, { passive: true });
    }

    // --- Animation loop, paused when hero offscreen or tab hidden ---
    let visible = true;
    let inView = true;
    const io = new IntersectionObserver((entries) => {
      inView = entries[0]?.isIntersecting ?? true;
    });
    io.observe(canvas);
    document.addEventListener('visibilitychange', () => {
      visible = document.visibilityState === 'visible';
    });

    const clock = new THREE.Clock();
    function frame() {
      requestAnimationFrame(frame);
      if (!visible || !inView) return;
      const dt = Math.min(clock.getDelta(), 0.05);

      group.rotation.y += dt * 0.05;
      group.rotation.x += ((0.18 + targetY) - group.rotation.x) * 0.04;
      camera.position.x += ((targetX * 4) - camera.position.x) * 0.04;
      camera.lookAt(0, 0, 0);

      for (const p of pulses) {
        p.t += dt * p.speed;
        if (p.t >= 1) {
          p.t = 0;
          p.from = p.to;
          const next = adjacency[p.from];
          p.to = next.length ? next[Math.floor(Math.random() * next.length)] : p.from;
        }
        p.sprite.position.lerpVectors(nodes[p.from], nodes[p.to], p.t);
        const fade = Math.sin(p.t * Math.PI);
        (p.sprite.material as THREE.SpriteMaterial).opacity = 0.35 + fade * 0.65;
      }

      renderer.render(scene, camera);
    }

    if (reduced) {
      renderer.render(scene, camera);
    } else {
      frame();
    }
  }
</script>
